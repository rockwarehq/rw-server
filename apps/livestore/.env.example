HOST=::
PORT=30100
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rw_server
NATS_URL=nats://127.0.0.1:4222
NATS_CLIENT_NAME=rw-livestore

# Tag fixture helpers
GRAPH_DEVICE_ID=press7-plc
GRAPH_TAG_PATH=cycleTime
GRAPH_NODE_NAME=Press 7
