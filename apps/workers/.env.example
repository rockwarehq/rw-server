# apps/workers — dispatcher binary; pick one mode per process via --worker
#   --worker rollups            metric-bucket-ensure, ticks, archive, shift-*
#   --worker processor          MQTT ingest (rw-processor port) — STUB, not yet wired
#   --worker processor-consumer station-event-execution BullMQ consumer
#
# Copy to apps/workers/.env and fill in. In production these come from `fly secrets`.

# ── runtime
NODE_ENV=development
LOG_LEVEL=debug
PORT=9465
WORKER=rollups
CLOSE_GRACE_DELAY=500

# ── rollups mode: metrics combined tick
# Interval (ms) for the combined metrics tick. Default 5000. Raise to cut
# Redis pub/sub bandwidth (each tick re-publishes a full snapshot per active
# bucket) at the cost of staler KPIs. Only the `rollups` worker reads this.
# COMBINED_TICK_MS=5000

# ── database
# DATABASE_URL is used by processor + processor-consumer modes. In prod
# against PSDB this is the pooled (pgbouncer, port 6432) endpoint — cycle
# transactions are short enough for tx-mode pooling after the cycle.complete
# refactor.
#
# DATABASE_URL_ROLLUPS overrides DATABASE_URL for the `rollups` mode only.
# Rollups run long CTE queries (combinedTick, cascade*) that pgbouncer
# transaction-mode either breaks or holds-open for the whole transaction,
# defeating the pool. Point this at the DIRECT (port 5432) endpoint.
# Unset = fall back to DATABASE_URL (fine in local dev where both are the
# same Postgres).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rockware
# DATABASE_URL_ROLLUPS=postgres://postgres:postgres@localhost:5432/rockware
#
# DATABASE_URL_MIGRATION is read by `prisma migrate deploy` (via fly's
# [deploy] release_command). Same direct endpoint as DATABASE_URL_ROLLUPS;
# kept as a separate variable so migration plumbing is clearly named.
# DATABASE_URL_MIGRATION=postgres://postgres:postgres@localhost:5432/rockware

# ── redis (same value in apps/api/.env)
REDIS_URL=redis://localhost:6379

# ── nats (rollups: metric graph bridge; processor: tag publish to livestore)
# Unset or empty = graph publishing disabled, worker runs normally.
NATS_URL=nats://127.0.0.1:4222

# ── bullmq tuning (optional — defaults work for standard Redis)
# BULLMQ_STALLED_INTERVAL=30000
# BULLMQ_DRAIN_DELAY=5000
# BULLMQ_CONNECT_TIMEOUT=10000

# ════════════════════════════════════════════════════════════════════
# processor mode only (MQTT ingest — ignore these for rollups / processor-consumer)
# ════════════════════════════════════════════════════════════════════

MQTT_BROKER_URL=mqtts://sim-mqtt.rockware.io:443
MQTT_TOPIC=#
MQTT_USERNAME=gateway
MQTT_PASSWORD=replace-me

# Signs the cache-refresh callback from api (must match apps/api PROCESSOR_SHARED_SECRET)
PROCESSOR_SHARED_SECRET=replace-with-strong-secret

PROCESSOR_CONCURRENCY=2
PROCESSOR_QUEUE_CAPACITY=100
PROCESSOR_TIMEOUT_MS=5000
PROCESSOR_OVERFLOW_POLICY=drop_oldest
SHUTDOWN_DRAIN_TIMEOUT_MS=10000

METRICS_INTERVAL_MS=10000
METRICS_ENABLED=true
METRICS_HOST=0.0.0.0
METRICS_PORT=9464
METRICS_PATH=/metrics

# Downstream processor toggles — flip on the ones the tenant uses.
DB_EVENTS_ENABLED=false
DB_EVENTS_CONNECTION_STRING=
DB_EVENTS_TABLE=PointValue
DB_EVENTS_INSERT_TIMEOUT_MS=2000
DB_EVENTS_BATCH_WINDOW_MS=1000
DB_EVENTS_BATCH_MAX_ROWS=100
DB_EVENTS_RUNTIME_CONCURRENCY=100
DB_EVENTS_RUNTIME_QUEUE_CAPACITY=1000
DB_EVENTS_RUNTIME_TIMEOUT_MS=10000

STATION_EVENTS_ENABLED=false
STATION_EVENTS_URL=http://localhost:30000/internal/station-events
STATION_EVENTS_TIMEOUT_MS=2000
STATION_EVENTS_TAG_FETCH_BATCH_SIZE=100
STATION_EVENTS_PREWARM_TAG_CACHE=true
STATION_EVENTS_TAG_SNAPSHOT_CACHE_MAX_ENTRIES=50000
STATION_EVENTS_RUNTIME_CONCURRENCY=2
STATION_EVENTS_RUNTIME_QUEUE_CAPACITY=100
STATION_EVENTS_RUNTIME_TIMEOUT_MS=5000
STATION_EVENTS_CACHE_REFRESH_ENABLED=true
STATION_EVENTS_CACHE_REFRESH_HOST=0.0.0.0
STATION_EVENTS_CACHE_REFRESH_PORT=9465
STATION_EVENTS_CACHE_REFRESH_PATH=/internal/cache/refresh

# WORKSPACE_HTTP_EVENTS_ENABLED=false
# WORKSPACE_HTTP_EVENTS_URL=
# WORKSPACE_HTTP_TIMEOUT_MS=2000

# CONSOLE_EVENTS_ENABLED=false
# FILE_EVENTS_ENABLED=false
# FILE_EVENTS_PATH=
# UNIQUE_TOPICS_ENABLED=false
# POINTS_SPLIT_ENRICH_ENABLED=false
# POINTS_SPLIT_ENRICH_MODE=strict
