{
  "name": "@rw/workers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "start:rollups": "node dist/main.js --worker rollups",
    "dev:rollups": "tsx watch src/main.ts --worker rollups",
    "start:imm-events": "node dist/main.js --worker imm-events",
    "dev:imm-events": "tsx watch src/main.ts --worker imm-events",
    "publish:cycles": "tsx scripts/publish-cycles.ts",
    "seed:station": "tsx scripts/seed-station.ts",
    "seed:rollup-set": "tsx scripts/seed-rollup-set.ts",
    "reseed:graph": "tsx scripts/reseed-graph.ts",
    "add:cycle-hooks": "tsx scripts/add-cycle-hooks.ts",
    "publish:counter": "tsx scripts/publish-counter.ts"
  },
  "dependencies": {
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/nats-core": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "@orpc/client": "^1.14.3",
    "@orpc/server": "^1.14.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@rw/db": "workspace:*",
    "@rw/runtime": "workspace:*",
    "@rw/services": "workspace:*",
    "better-result": "^2.9.2",
    "bullmq": "^5.66.5",
    "dotenv": "^17.2.3",
    "ioredis": "^5.10.1",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.8",
    "@types/uuid": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2"
  }
