# apps/api — HTTP/RPC/auth server + in-process workers
# (stale-gateway-check, replay-reconcile, station-detect, dev-cycle-simulator)
#
# Copy to apps/api/.env and fill in. In production these come from `fly secrets`.

# ── runtime
NODE_ENV=development
LOG_LEVEL=debug
NODE_ID=gateway-001
HOST=0.0.0.0
PORT=30000
CLOSE_GRACE_DELAY=500

# ── database
# DATABASE_URL = pooled (pgbouncer transaction mode) endpoint — used at runtime
# DATABASE_URL_MIGRATION = direct endpoint — used by `prisma migrate` (sessions,
#                          advisory locks, DDL require a real connection).
#                          Also consumed by fly's [deploy] release_command.
# In dev with self-hosted Postgres, both can point at the same URL. In prod
# against PSDB / Supabase / Neon, set them to the pooled and direct endpoints
# respectively.
DATABASE_URL=postgres://postgres:postgres@localhost:6432/rockware
DATABASE_URL_MIGRATION=postgres://postgres:postgres@localhost:5432/rockware

# ── redis (same value in apps/workers/.env)
REDIS_URL=redis://localhost:6379

# ── nats (graph definition events to livestore)
# Unset or empty = graph definition publishing disabled, API writes still succeed.
NATS_URL=nats://127.0.0.1:4222

# ── auth
JWT_SECRET=replace-with-strong-secret

# ── processor-shared secret (signs callbacks between api and workers/processor)
PROCESSOR_SHARED_SECRET=replace-with-strong-secret

# ── email (Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@notify.rockware.io
# Browser-facing base URL: email links + CORS allowlist. Required (https) in production.
APP_BASE_URL=http://localhost:3000
# Extra allowed browser origins, comma-separated, additive to APP_BASE_URL.
# In development, leaving this unset allows all origins.
# CORS_ALLOWED_ORIGINS=https://staging.rockware.io

# ── S3 / object storage (optional — file uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
# BUCKET_NAME=
# DOCUMENT_MAX_FILE_SIZE_BYTES=52428800
# DOCUMENT_ALLOWED_CONTENT_TYPES=application/pdf,text/plain,text/markdown,text/csv,application/json,image/jpeg,image/png,image/webp,image/gif,image/svg+xml,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation



# ── processor cache refresh callback (optional — api → workers/processor)
# PROCESSOR_CACHE_REFRESH_URL=http://localhost:9465/internal/cache/refresh
# PROCESSOR_CACHE_REFRESH_SECRET=
# PROCESSOR_CACHE_REFRESH_TIMEOUT_MS=2000

# ── station actions (optional)
# STATION_ACTION_WEBHOOK_TIMEOUT_MS=5000

# ── bullmq tuning (optional — defaults work for standard Redis)
# BULLMQ_STALLED_INTERVAL=30000
# BULLMQ_DRAIN_DELAY=5000
# BULLMQ_CONNECT_TIMEOUT=10000

# ── dev-only
# DEV_CYCLE_SIMULATOR=1
# DEV_CYCLE_SIMULATOR_INTERVAL_MS=10000
