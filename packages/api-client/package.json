{
  "name": "@rockwarehq/api-client",
  "version": "0.5.0",
  "description": "Generated API client for Rockware API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "pnpm exec openapi-ts && node -e \"const fs=require('fs');const f='src/generated/index.ts';let c=fs.readFileSync(f,'utf8');c=c.replace('./react-query.gen','./@tanstack/react-query.gen');fs.writeFileSync(f,c);\"",
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "0.9.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.91.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rockwarehq/rw-server.git",
    "directory": "packages/api-client"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
