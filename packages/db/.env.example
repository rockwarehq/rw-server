# packages/db — used by `pnpm db:generate` / `pnpm db:migrate` /
# `pnpm db:migrate:dev` / `pnpm db:seed`.
#
# Copy to packages/db/.env and fill in. Apps load their own .env at runtime;
# this file is only consulted by the Prisma CLI from the workspace root.
#
# `prisma migrate` prefers DATABASE_URL_MIGRATION (sessions / advisory locks /
# DDL don't work through pgbouncer transaction mode), falling back to
# DATABASE_URL. In a non-pooled setup, leave DATABASE_URL_MIGRATION unset.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/rockware
DATABASE_URL_MIGRATION=postgres://postgres:postgres@localhost:5432/rockware
