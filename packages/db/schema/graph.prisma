model GraphNode {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  siteId      String  @db.Uuid
  typeRef     String?
  typeContext Json    @default("{}")
  facets      Json    @default("{}")
  isDeleted   Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  properties GraphProperty[]
  site       Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, name])
  @@index([siteId])
  @@index([siteId, typeRef])
  @@index([facets], type: Gin)
  @@index([isDeleted])
}

model GraphProperty {
  id           String  @id @default(uuid()) @db.Uuid
  nodeId       String  @db.Uuid
  typeFieldKey String?
  name         String
  resolverType String
  resolver     Json
  sampleRateMs Int?
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  node     GraphNode   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  edgesIn  GraphEdge[] @relation("ToProperty")
  edgesOut GraphEdge[] @relation("FromProperty")

  @@unique([nodeId, name])
  @@index([nodeId, typeFieldKey])
  @@index([resolverType])
  @@index([isDeleted])
}

model GraphNodeType {
  id          String  @id @default(uuid()) @db.Uuid
  siteId      String  @db.Uuid
  key         String
  label       String
  description String?
  isDeleted   Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  site   Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  inputs GraphNodeTypeInput[]
  facets GraphNodeTypeFacet[]
  fields GraphNodeTypeField[]

  @@unique([siteId, key])
  @@index([siteId])
  @@index([isDeleted])
}

model GraphNodeTypeInput {
  id          String  @id @default(uuid()) @db.Uuid
  typeId      String  @db.Uuid
  key         String
  label       String
  description String?
  valueType   String
  entityKey   String?
  required    Boolean @default(false)
  sortOrder   Int     @default(0)
  isDeleted   Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  type GraphNodeType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([typeId, key])
  @@index([typeId])
  @@index([isDeleted])
}

model GraphNodeTypeFacet {
  id           String  @id @default(uuid()) @db.Uuid
  typeId       String  @db.Uuid
  key          String
  label        String
  description  String?
  valueType    String?
  required     Boolean @default(false)
  resolverType String
  resolver     Json
  sortOrder    Int     @default(0)
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  type GraphNodeType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([typeId, key])
  @@index([typeId])
  @@index([resolverType])
  @@index([isDeleted])
}

model GraphNodeTypeField {
  id           String  @id @default(uuid()) @db.Uuid
  typeId       String  @db.Uuid
  key          String
  label        String
  description  String?
  valueType    String
  required     Boolean @default(false)
  resolverType String
  resolver     Json
  sampleRateMs Int?
  sortOrder    Int     @default(0)
  isDeleted    Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  type GraphNodeType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([typeId, key])
  @@index([typeId])
  @@index([isDeleted])
}

model GraphEdge {
  id             String @id @default(uuid()) @db.Uuid
  fromPropertyId String @db.Uuid
  toPropertyId   String @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  fromProperty GraphProperty @relation("FromProperty", fields: [fromPropertyId], references: [id], onDelete: Cascade)
  toProperty   GraphProperty @relation("ToProperty", fields: [toPropertyId], references: [id], onDelete: Cascade)

  @@unique([fromPropertyId, toPropertyId])
  @@index([fromPropertyId])
  @@index([toPropertyId])
}

model GraphHook {
  id            String  @id @default(uuid()) @db.Uuid
  siteId        String  @db.Uuid
  name          String
  enabled       Boolean @default(true)
  condition     Json
  /// Deprecated: use eventNamespace + eventName for NATS-safe routing.
  legacyEventType String @default("livestore_hook_triggered") @map("eventType")
  eventNamespace String  @default("livestore")
  eventName      String  @default("hook_triggered")
  eventVersion  String  @default("1")
  eventPayload  Json    @default("{}")
  eventContext  Json    @default("{}")
  isDeleted     Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, name])
  @@index([siteId, enabled])
  @@index([isDeleted])
  @@index([eventNamespace, eventName])
}
