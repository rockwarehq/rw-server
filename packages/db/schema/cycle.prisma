enum CycleStatus {
  DISCARD
  BAD
  GOOD
}

model Cycle {
  id           String      @id @default(uuid()) @db.Uuid
  rejectNumber Int         @default(0)
  cycleStatus  CycleStatus

  // Timing
  start          DateTime  @db.Timestamptz(3)
  end            DateTime? @db.Timestamptz(3)
  equipmentStart DateTime? @db.Timestamptz(3)
  equipmentEnd   DateTime? @db.Timestamptz(3)

  attrs Json @default("{}")

  siteId String @db.Uuid
  site   Site   @relation(fields: [siteId], references: [id])

  stationId String  @db.Uuid
  station   Station @relation(fields: [stationId], references: [id])

  orderId String?    @db.Uuid
  order   WorkOrder? @relation(fields: [orderId], references: [id])

  // Snapshot: version IDs at point in time
  stationVersionId String?         @db.Uuid
  stationVersion   StationVersion? @relation(fields: [stationVersionId], references: [id])

  jobVersionId String     @db.Uuid
  jobVersion   JobVersion @relation(fields: [jobVersionId], references: [id])

  toolVersions ToolVersion[]

  jobTools JobTool[]

  inventoryItems      InventoryItem[]
  itemDispositionLogs ItemDispositionLog[]

  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([stationId, end])
  @@index([siteId, end])
  @@index([siteId, deletedAt, end])
  @@index([stationId, deletedAt, end])
  @@index([jobVersionId])
  @@index([orderId])
}
