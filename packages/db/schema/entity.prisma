enum ObjectFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  TIMESTAMP
  SELECT
  JSON
  OBJECT
}

enum ObjectSchemaSource {
  RECORD
  DOCUMENT
}

model ObjectSchema {
  id          String  @id @default(uuid()) @db.Uuid
  key         String
  label       String
  name        String
  description String?
  source      ObjectSchemaSource @default(DOCUMENT)
  meta        Json               @default("{}")
  displayFieldKey String?
  isSystem    Boolean            @default(false)
  version     Int     @default(1)
  isDeleted   Boolean @default(false)

  workspaceId String?    @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  siteId      String?    @db.Uuid
  site        Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  fields             ObjectSchemaField[] @relation("SchemaFields")
  referencedByFields ObjectSchemaField[] @relation("FieldRefSchema")
  instances          ObjectInstance[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([siteId, key])
  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([siteId])
  @@index([source])
  @@index([isSystem])
  @@index([isDeleted])
}

model ObjectSchemaField {
  id       String       @id @default(uuid()) @db.Uuid
  schemaId String       @db.Uuid
  schema   ObjectSchema @relation("SchemaFields", fields: [schemaId], references: [id], onDelete: Cascade)

  name        String
  key         String
  label       String
  description String?
  type        ObjectFieldType
  refSchemaId String?         @db.Uuid
  refSchema   ObjectSchema?   @relation("FieldRefSchema", fields: [refSchemaId], references: [id], onDelete: SetNull)
  isList      Boolean         @default(false)
  required    Boolean         @default(false)
  config      Json?
  sortOrder   Int             @default(0)
  isDeleted   Boolean         @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([schemaId, key])
  @@unique([schemaId, name])
  @@index([schemaId])
  @@index([refSchemaId])
  @@index([type])
  @@index([isDeleted])
}

model ObjectInstance {
  id       String       @id @default(uuid()) @db.Uuid
  schemaId String       @db.Uuid
  schema   ObjectSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  siteId   String?      @db.Uuid
  site     Site?        @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name      String
  values    Json    @default("{}")
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([schemaId])
  @@index([siteId])
  @@index([siteId, schemaId, isDeleted])
  @@index([schemaId, isDeleted])
  @@index([values], type: Gin)
}
